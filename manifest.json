{
  "manifest_version": 3,
  "name": "More Buttons",
  "version": "0.7.1",
  "description": "More buttons and automations!",
  "permissions": ["storage", "activeTab", "tabs", "debugger"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "host_permissions": ["https://cloud.opus-safety.co.uk/*"],
  "web_accessible_resources": [
    {
      "resources": [
        "config/containers.json",
        "config/buttons.json",
        "config/automations.json",
        "config/labelColours.json",
        "config/lucideIcons.json",
        "scripts/actions.js",
        "scripts/admonitions.js",
        "scripts/sections.js",
        "scripts/captures.js",
        "scripts/captureMeta.js",
        "scripts/form.js",
        "scripts/formValidation.js",
        "scripts/loading.js",
        "scripts/formActions.js",
        "scripts/github.js",
        "scripts/repoClient.js",
        "scripts/navToml.js",
        "scripts/staleSuppression.js",
        "scripts/cardRenderer.js",
        "scripts/systemStatus.js",
        "scripts/systemUpdates.js",
        "scripts/guides.js",
        "scripts/markdownInline.js",
        "scripts/markdownToolbarActions.js",
        "scripts/richTextEditor.js",
        "scripts/richEditorMapping.js",
        "scripts/buttons.js",
        "scripts/containers.js",
        "scripts/automations.js",
        "scripts/utils.js",
        "scripts/navigateToNewDocumentPage.js",
        "scripts/clearAllCheckboxes.js",
        "scripts/setAnnualDocumentDefault.js",
        "scripts/copyQuestions.js",
        "scripts/auditCSVExport.js",
        "scripts/navigateToEmployeePageForRegEmail.js",
        "scripts/generateAndDisplayRegEmail.js",
        "scripts/copyEmailFromEmailIframe.js",
        "scripts/copyRoleCheckboxValue.js",
        "scripts/initSiteQRPosterGeneration.js",
        "scripts/createSiteQRCode.js",
        "scripts/generateSiteQRPosterPDF.js",
        "scripts/highlightPackageTemplateInMPP.js",
        "scripts/setAccess.js",
        "scripts/employeeRecordAccessEditEnhancement.js",
        "scripts/fillInputsFromPreset.js",
        "scripts/applyAdvancedNavigation.js",
        "scripts/mergeIndicatorsEnhancement.js",
        "scripts/questionSectionToggle.js",
        "scripts/toggleContainerVisibility.js",
        "scripts/updateFocusParam.js",
        "scripts/bulkRevisionDownload.js",
        "scripts/smartDocumentSubmit.js",
        "scripts/copySitesToClipboard.js",
        "scripts/uninstallAllNonSystemReportTypes.js",
        "scripts/applyReportTypePreset.js",
        "scripts/siteListFocusIcons.js",
        "scripts/attachColorPresetPills.js",
        "scripts/captureElement.js",
        "scripts/captureGeometry.js",
        "scripts/captureMode.js",
        "scripts/toggleMoreButtonsActive.js",
        "scripts/knowledgeBaseManagement.js",
        "scripts/kbTree.js",
        "scripts/kbReorder.js",
        "scripts/navTree.js",
        "scripts/captureLibrary.js",
        "scripts/captureEntry.js",
        "scripts/captureNew.js",
        "scripts/captureInsertNew.js",
        "scripts/captureCards.js",
        "scripts/integrations.js",
        "scripts/components.js",
        "scripts/componentContainers.js",
        "scripts/insertMenu.js",
        "scripts/captureComponent.js",
        "scripts/contentTabs.js",
        "scripts/contentTabsEditor.js",
        "scripts/dataTables.js",
        "scripts/dataTablesEditor.js",
        "scripts/grid.js",
        "scripts/gridEditor.js",
        "scripts/mdButtons.js",
        "scripts/buttonEditor.js",
        "scripts/navLinks.js",
        "scripts/navLinksEditor.js",
        "scripts/mdDiagrams.js",
        "scripts/diagramEditor.js",
        "scripts/formMerge.js",
        "scripts/conflictResolver.js",
        "scripts/mergeSave.js",
        "scripts/frontmatter.js",
        "scripts/iconPicker.js",
        "scripts/videos.js",
        "scripts/videoEntry.js",
        "scripts/videoCards.js",
        "scripts/mediaTree.js"
      ],
      "matches": ["https://cloud.opus-safety.co.uk/*"]
    },
    {
      "resources": ["config/forms/*"],
      "matches": ["https://cloud.opus-safety.co.uk/*"]
    },
    {
      "resources": ["assets/fonts/*"],
      "matches": ["https://cloud.opus-safety.co.uk/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://cloud.opus-safety.co.uk/admin/sites/*/qrs/*"],
      "js": ["scripts/libs/qrcode.min.js", "scripts/libs/jspdf.umd.min.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://cloud.opus-safety.co.uk/admin/sites/*/documents/*"],
      "js": ["scripts/libs/pdf-lib.min.js", "scripts/libs/jszip.min.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://cloud.opus-safety.co.uk/*"],
      "js": ["scripts/content.js"],
      "run_at": "document_start"
    }
  ]
}
